# Auth Configuration (Development)
# Replace with your actual Azure AD credentials

# Azure AD Client ID
# Get this from Azure Portal > App registrations > Your app > Application (client) ID
AZURE_CLIENT_ID=

# Azure AD Authority
AZURE_AUTHORITY=https://login.microsoftonline.com/common

# Redirect URI (must match your app registration redirect URIs)
# Development: http://localhost:4200
# Production: https://yourdomain.com
AZURE_REDIRECT_URI=http://localhost:4200
